# shop1031-extract environment template. Copy to .env and fill in only the keys
# you want. EVERY variable here is OPTIONAL. Core extraction, multi-path
# verification, and photo de-layering all run fully offline and free with NONE of
# these set. These keys only enrich verification confidence and provide photo
# fallbacks. There is no LLM key anywhere because the pipeline makes zero LLM
# calls.

# Google Maps API key. OPTIONAL. Used by two optional paths: Leg 2.5 geocoding
# confirmation (api_confirm.py) and the Street View photo fallback (photos
# fallback chain). With no key, geocoding is skipped and Street View falls
# through to the next fallback. Free tier available from Google Cloud Console.
GOOGLE_MAPS_API_KEY=your-google-maps-key-here

# Mapbox access token. OPTIONAL. Used only by the aerial photo fallback when
# raw extraction and overlay reconstruction both fail and Street View is
# unavailable. With no token, aerial is skipped and the OM routes to the human
# review queue. Free tier available from Mapbox.
MAPBOX_TOKEN=your-mapbox-token-here

# Cloudflare R2 source-PDF preservation (r2_preserve.py). OPTIONAL and fully
# env-gated. With nothing set, preserve() records a canonical handle offline and
# makes no network call. Upload happens only when R2_BUCKET is set AND the
# wrangler CLI is on PATH (preservation shells out to wrangler, so no R2 access
# key or secret is read here).
# Target R2 bucket name. Set this to enable wrangler upload.
R2_BUCKET=your-r2-bucket-name
# Public base URL the preserved PDFs are addressed under.
R2_PUBLIC_BASE=https://oms.example.com
# Set to 1 to mirror preserved PDFs into a local store instead of uploading.
R2_MIRROR=0

# Output root for optional artifacts (r2 manifest, Leg 2.5 cache). OPTIONAL.
# Defaults to a sibling out/ folder if unset.
SHOP1031_EXTRACT_OUT=./out

# SEC EDGAR User-Agent. OPTIONAL. EDGAR asks callers to identify themselves with
# a descriptive User-Agent (name + contact). Only used by the optional Leg 2.5
# tenant-issuer confirmation. A safe default is used if unset.
EDGAR_USER_AGENT=your-app-name your-contact@example.com

# Known-truth OM corpus folder. OPTIONAL. Only used by the internal accuracy
# harness (score_corpus.py). Point it at a folder holding an extracted/
# subfolder of ground-truth deal_data.json folders with matching source PDFs.
SHOP1031_OM_CORPUS=/path/to/your/om-corpus
